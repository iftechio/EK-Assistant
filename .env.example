# ---- Gateway (apps/gateway/.env) ----
ASSISTANT_PORT=3002
# talent-marking-backend 地址（JWT 原样转发）
BACKEND_BASE_URL=http://localhost:3000
# EK-Assistant 自己的会话库（Postgres，可用公司 RDS，表前缀 assistant_）
ASSISTANT_DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public
# 与 backend 相同的 Supabase JWT 对称密钥（HS256 本地验签；不配则仅解码不验签）
SUPABASE_JWT_SECRET=
# 模型池与 failover 顺序（provider:modelId，逗号分隔）
# 支持 provider：gemini(Google AI Studio) / deepseek / aihubmix / openrouter
# aihubmix/openrouter 与 backend infras/ai 同通道，可直接复用 backend 的 key
ASSISTANT_MODEL_FAILOVER_ORDER=aihubmix:gemini-2.5-flash,openrouter:google/gemini-2.5-flash
AIHUBMIX_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 单会话配额消耗上限（超限的消耗性操作需用户确认）
ASSISTANT_SESSION_QUOTA_CAP=200
# 上下文 token 预算（超过触发压缩）
ASSISTANT_CONTEXT_TOKEN_BUDGET=24000

# ---- Web (apps/web/.env) ----
