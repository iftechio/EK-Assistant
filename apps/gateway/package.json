{
  "name": "@ek-assistant/gateway",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "openapi": "openapi-typescript http://localhost:3000/api/swagger/json -o src/backend/openapi.d.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@fastify/cors": "^10.0.0",
    "ai": "^5.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "jose": "^5.9.0",
    "pg": "^8.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.0",
    "openapi-typescript": "^7.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
